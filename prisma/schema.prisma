// Prisma Schema for LensFlow CRM — Multi-Tenant Architecture
// One production hub (laboratory), many clinics and doctors

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== Organization (Clinic / Optic) ====================
model Organization {
  id        String   @id @default(cuid())
  name      String
  type      OrgType  @default(standalone)
  inn       String?   // БИН/ИИН
  phone     String?
  email     String?
  address   String?   // Юридический адрес
  city      String?
  crmPhone  String?   // Номер WhatsApp для CRM-интеграции филиала

  // Multi-branch: self-relation
  parentId  String?
  parent    Organization?  @relation("OrgBranches", fields: [parentId], references: [id])
  branches  Organization[] @relation("OrgBranches")

  // Дополнительные реквизиты
  actualAddress    String?  // Фактический адрес
  deliveryAddress  String?  // Адрес доставки
  bankName         String?  // Название банка
  bik              String?  // БИК банка
  iban             String?  // IBAN / расчётный счёт
  bankName2        String?  // Название банка 2
  bik2             String?  // БИК банка 2
  iban2            String?  // IBAN / расчётный счёт 2
  bankName3        String?  // Название банка 3
  bik3             String?  // БИК банка 3
  iban3            String?  // IBAN / расчётный счёт 3
  directorName     String?  // ФИО руководителя
  registrationDate String?  // Дата регистрации
  contactPerson    String?  // Контактное лицо
  contactPhone     String?  // Телефон контактного лица
  discountPercent  Float    @default(0)  // Персональная скидка (%), по умолчанию 0%
  logo             String?  @db.Text     // URL логотипа организации
  metadata         Json?    // Integrations config (ITIGRIS, etc.)
  allowedPartnerIds String[] @default([]) // Массив ID лабораторий, доступных этому филиалу

  status    OrgStatus @default(active)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users    User[]
  orders   Order[]
  patients Patient[]

  // Inventory & POS
  opticProducts   OpticProduct[]
  stockItems      StockItem[]
  stockDocuments  StockDocument[]
  stockMovements  StockMovement[]
  sales           Sale[]
  inventories     Inventory[]

  // CRM Sales
  clinicLeads         Lead[]               @relation("ClinicLeads")
  clinicSubscription  ClinicSubscription[]  @relation("ClinicSubscription")

  cashRegisters CashRegister[]
  itigrisSyncLogs ItigrisSyncLog[]
  userBranches UserBranch[]

  // Distributor orders
  distributorOrders Order[] @relation("DistributorOrders")

  // Default lab for distributor (which lab they send orders to)
  defaultLabId  String?
  defaultLab    Organization?  @relation("DistributorDefaultLab", fields: [defaultLabId], references: [id])
  distributorClients Organization[] @relation("DistributorDefaultLab")

  // Lab orders (orders forwarded to this lab by a distributor)
  labOrders Order[] @relation("LabOrders")

  // Contracts
  providedContracts Contract[] @relation("ContractProvider")
  clientContracts   Contract[] @relation("ContractClient")

  marketingCampaigns MarketingCampaign[]
  appointments       Appointment[]

  // Finances
  companyAccounts        CompanyAccount[]
  financialTransactions  FinancialTransaction[]
  payrollRules           PayrollRule[]
  payrollPayouts         PayrollPayout[]

  @@map("organizations")
}

enum OrgType {
  standalone
  headquarters
  branch
  distributor
  laboratory
}

// ==================== Itigris Sync Log ====================
model ItigrisSyncLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncedAt       DateTime     @default(now())
  entity         String       // 'clients' | 'orders' | 'full'
  created        Int          @default(0)
  updated        Int          @default(0)
  errors         Int          @default(0)
  details        Json?
  triggeredBy    String?      // userId or 'manual'
  durationMs     Int?

  @@map("itigris_sync_logs")
}

// ==================== Lab Settings (singleton) ====================
model LabSettings {
  id                      String @id @default("default")
  urgentSurchargePercent   Int    @default(25)
  urgentDiscountPercent    Int    @default(0)
  updatedAt               DateTime @updatedAt

  @@map("lab_settings")
}

enum OrgStatus {
  pending
  active
  blocked
}

// ==================== User ====================
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  fullName       String    @default("")
  phone          String?
  avatar         String?   @db.Text
  role           UserRole
  subRole        SubRole
  status         UserStatus @default(active)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  discountPercent Float?        // Персональная скидка для независимых врачей (%)
  permissions    Json?          // Настройки прав видимости модулей клиники
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders Order[] @relation("CreatedBy")
  supportTickets SupportTicket[]
  assignedLeads  Lead[]  @relation("AssignedLeads")
  doctorLeads    Lead[]  @relation("DoctorLeads")
  doctorSales    Sale[]  @relation("SaleDoctor")
  patients       Patient[] @relation("DoctorPatients")
  prescriptions  Prescription[] @relation("DoctorPrescriptions")
  consultations  Consultation[] @relation("DoctorConsultations")
  appointments   Appointment[]  @relation("DoctorAppointments")

  openedShifts      CashShift[]       @relation("OpenedShifts")
  closedShifts      CashShift[]       @relation("ClosedShifts")
  cashTransactions  CashTransaction[] @relation("CreatedTransactions")
  branches          UserBranch[]

  // Finances
  payrollRules           PayrollRule[]
  payrollPayouts         PayrollPayout[]
  financialTransactionsCreated FinancialTransaction[] @relation("FinancialTransactionsCreated")
  financialTransactionsLinked  FinancialTransaction[] @relation("FinancialTransactionsLinked")

  @@map("users")
}

// ==================== User ↔ Branch (M2M) ====================
model UserBranch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Organization @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@map("user_branches")
}

enum UserRole {
  doctor
  optic
  laboratory
  distributor
}

enum SubRole {
  lab_engineer
  lab_quality
  lab_logistics
  lab_head
  lab_admin
  lab_accountant
  optic_manager
  optic_doctor
  optic_accountant
  optic_procurement
  doctor
  sales_manager
  dist_head
  dist_admin
  dist_manager
  dist_accountant
}

enum UserStatus {
  pending
  active
  blocked
}

// ==================== Patient ====================
model Patient {
  id             String  @id @default(cuid())
  medmundusId    Int?    @unique  // MedMundus Patient.id for cross-system sync
  name           String
  phone          String
  email          String?
  birthDate      DateTime?
  gender         String?   // male | female
  notes          String?   @db.Text
  attachments    Json?     // [{ name, url, type, size, uploadedAt }]
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  doctorId       String?
  doctor         User?    @relation("DoctorPatients", fields: [doctorId], references: [id])

  // External integrations (ITIGRIS, etc.)
  externalId     String?  // e.g. "itigris:12345"
  externalSource String?  // e.g. "itigris"

  // General Medical / Anamnesis
  iin              String?
  address          String?
  profession       String?
  complaints       String?   @db.Text
  anamnesisDisease String?   @db.Text
  anamnesisLife    String?   @db.Text
  allergies        String?   @db.Text
  heredity         String?   @db.Text
  medications      String?   @db.Text
  dispensary       String?   @db.Text
  surgeries        String?   @db.Text
  lastCorrection   String?   @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  orders        Order[]
  prescriptions Prescription[]
  consultations Consultation[]
  sales         Sale[]
  leads         Lead[]
  appointments  Appointment[]

  @@index([organizationId])
  @@index([phone])
  @@index([medmundusId])
  @@index([externalId])
  @@map("patients")
}

// ==================== Prescription (Vision Rx History) ====================
model Prescription {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String?
  doctor      User?    @relation("DoctorPrescriptions", fields: [doctorId], references: [id])

  // Right eye (OD)
  odSph       Float?
  odCyl       Float?
  odAx        Float?
  odAdd       Float?
  odPd        Float?

  // Left eye (OS)
  osSph       Float?
  osCyl       Float?
  osAx        Float?
  osAdd       Float?
  osPd        Float?

  // General
  pdTotal     Float?   // Total PD if measured together
  type        String   @default("glasses") // glasses | contacts | ortho-k
  notes       String?  @db.Text
  prescribedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([patientId])
  @@map("prescriptions")
}

// ==================== Consultation (Visit History) ====================
model Consultation {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId    String?
  doctor      User?    @relation("DoctorConsultations", fields: [doctorId], references: [id])

  visitDate   DateTime @default(now())   // Date of the visit
  type        String   @default("exam")  // exam | follow_up | fitting | other
  diagnosis   String?  @db.Text          // Clinical notes / diagnosis
  treatment   String?  @db.Text          // Treatment plan / recommendation
  nextVisit   DateTime?                  // Scheduled next appointment
  intraocularPressureOD Float?           // IOP OD (mmHg)
  intraocularPressureOS Float?           // IOP OS
  visualAcuityOD Float?                  // Visual acuity OD (e.g. 0.8)
  visualAcuityOS Float?                  // Visual acuity OS

  // Topography / Keratometry OD
  k1OD             Float?
  k2OD             Float?
  axisOD           Float?
  astigmatismOD    Float?
  pachymetryOD     Float?
  eccentricityOD   Float?

  // Topography / Keratometry OS
  k1OS             Float?
  k2OS             Float?
  axisOS           Float?
  astigmatismOS    Float?
  pachymetryOS     Float?
  eccentricityOS   Float?

  // Lens Fitting & Refraction (Free Text)
  lensFittingOD    String?   @db.Text
  lensFittingOS    String?   @db.Text
  refractionOD     String?   @db.Text
  refractionOS     String?   @db.Text

  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([patientId])
  @@index([visitDate])
  @@map("consultations")
}

// ==================== Product Catalog ====================
model Product {
  id          String   @id @default(cuid())
  name        String
  category    String   // lens, solution, accessory
  sku         String?  @unique
  name1c      String?  // Наименование в 1С
  code        String?  // Код товара
  description String?
  price       Int      @default(0)
  priceByDk   Json?    // { "50": 7600, "100": 18500, ... } DK-specific prices for lenses (clinic/optic price)
  distributorPriceByDk Json? // { "50": 7600, "100": 18500, ... } DK-specific prices for distributors
  unit        String   @default("шт")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

// ==================== Appointment (Doctor Schedule) ====================
model Appointment {
  id           String        @id @default(cuid())
  patientId    String?
  patient      Patient?      @relation(fields: [patientId], references: [id])
  patientName  String?
  patientPhone String?
  doctorId     String?
  doctor       User?         @relation("DoctorAppointments", fields: [doctorId], references: [id])
  clinicId     String?
  clinic       Organization? @relation(fields: [clinicId], references: [id])
  
  date         DateTime
  duration     Int           @default(30) // in minutes
  status       String        @default("scheduled") // scheduled | completed | cancelled | no_show
  type         String        @default("consultation") // consultation | fitting | checkup | other
  notes        String?       @db.Text

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([doctorId, date])
  @@index([clinicId])
  @@map("appointments")
}

// ==================== Order ====================
model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  status          OrderStatus @default(new_order)
  isUrgent        Boolean     @default(false)

  // Relations
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  createdById     String?
  createdBy       User?        @relation("CreatedBy", fields: [createdById], references: [id])
  patientId       String?
  patient         Patient?     @relation(fields: [patientId], references: [id])

  // Meta
  opticName       String?
  doctorName      String?
  doctorEmail     String?
  company         String?
  inn             String?

  // Delivery
  deliveryMethod  String?
  deliveryAddress String?
  trackingNumber  String?

  // Lens Configuration (stored as JSON)
  lensConfig      Json

  // 1C Document names (auto-constructed from catalog name1c + характеристика + DK)
  documentNameOd  String?  // Наименование в 1С для OD
  documentNameOs  String?  // Наименование в 1С для OS
  priceOd         Int?     // Цена за единицу OD (из каталога по DK)
  priceOs         Int?     // Цена за единицу OS (из каталога по DK)

  // Payment
  totalPrice      Int           @default(0)
  discountPercent Float         @default(0)  // Скидка, применённая к заказу
  paymentStatus   PaymentStatus @default(unpaid)

  // Timestamps
  editDeadline          DateTime?
  productionStartedAt   DateTime?
  productionCompletedAt DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?

  // Notes & Defects
  notes   String?
  defects Json?   // Array of defect records
  comments Json?  // Array of comments: [{ authorId, authorName, role, text, createdAt }]

  // Delivery confirmation
  deliveryConfirmed  Boolean?

  // Ordered products snapshot: [{ productId, name, category, qty, price }]
  products Json?

  // Closing documents uploaded by accountant: [{ name, data (base64), mimeType, size, uploadedAt, uploadedBy }]
  closingDocuments Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // External integration (MedMundus)
  externalId String?  // MedMundus order ID for cross-referencing
  source     String?  // Origin: 'lensflow' | 'medmundus'

  // Distributor assignment
  distributorOrgId String?
  distributorOrg   Organization? @relation("DistributorOrders", fields: [distributorOrgId], references: [id])

  // Lab assignment (distributor forwards order to lab)
  labOrgId String?
  labOrg   Organization? @relation("LabOrders", fields: [labOrgId], references: [id])

  // Contract assignment
  contractId String?
  contract   Contract? @relation("OrderContract", fields: [contractId], references: [id])

  // CRM Lead link
  lead       Lead?

  @@map("orders")
}

// ==================== Contract ====================
model Contract {
  id          String   @id @default(cuid())
  number      String
  date        DateTime
  
  providerId  String
  provider    Organization @relation("ContractProvider", fields: [providerId], references: [id])
  
  clientId    String
  client      Organization @relation("ContractClient", fields: [clientId], references: [id])

  status      String   @default("active") // active | inactive
  customPrices Json?   // { "productId": 15000, "productId2": 12000 }
  document    Json?    // { name: string, data: string (base64), mimeType: string, size: number }

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]  @relation("OrderContract")

  @@map("contracts")
}

enum OrderStatus {
  new_order       @map("new")
  in_production
  ready
  rework
  docs_prep
  accountant_review
  docs_ready
  shipped
  out_for_delivery
  delivered
  cancelled
}

enum PaymentStatus {
  unpaid
  paid
  partial
}

// ==================== Support Tickets ====================
model SupportTicket {
  id           String       @id @default(cuid())
  title        String
  description  String       @db.Text
  category     String       @default("feature") // feature | bug | question
  status       TicketStatus @default(new_ticket)
  priority     String       @default("normal")  // low | normal | high

  authorId     String
  author       User         @relation(fields: [authorId], references: [id])

  adminComment String?      @db.Text

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("support_tickets")
}

enum TicketStatus {
  new_ticket   @map("new")
  in_progress
  done
  rejected
}

// ==================== Optic Product Catalog ====================
model OpticProduct {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  name             String
  slug             String?
  category         String          // frame | sun_glasses | contact_lens | spectacle_lens | solution | accessory | service_exam | service_fitting | service_cutting | service_repair | service_other
  type             String  @default("product")  // product | service

  brand            String?
  model            String?
  sku              String?
  barcode          String?
  shortDescription String?
  fullDescription  String?  @db.Text

  images           Json?    // ["url1.jpg", "url2.jpg"]
  specs            Json?    // { "material": "Пластик", ... }

  purchasePrice    Int      @default(0)
  retailPrice      Int      @default(0)

  minStock         Int      @default(0)
  currentStock     Int      @default(0)
  unit             String   @default("шт")
  trackSerials     Boolean  @default(false)

  isPublic         Boolean  @default(false)
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  stockItems       StockItem[]
  movements        StockMovement[]
  saleItems        SaleItem[]

  @@unique([organizationId, sku])
  @@map("optic_products")
}

// ==================== Stock Item (serial-tracked units) ====================
model StockItem {
  id              String   @id @default(cuid())
  productId       String
  product         OpticProduct @relation(fields: [productId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  serialNumber    String?
  barcode         String?

  status          String   @default("in_stock")
  // in_stock | reserved | sold | returned | defective | written_off

  color           String?
  size            String?
  sph             Float?
  cyl             Float?
  ax              Float?

  batchNumber     String?
  expiryDate      DateTime?
  purchasePrice   Int?

  receiptDocId    String?

  receivedAt      DateTime @default(now())
  soldAt          DateTime?
  notes           String?

  @@unique([organizationId, serialNumber])
  @@map("stock_items")
}

// ==================== Stock Movement (history log) ====================
model StockMovement {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  productId       String
  product         OpticProduct @relation(fields: [productId], references: [id])

  type            String   // receipt | sale | return_in | return_out | write_off | adjustment
  quantity        Int

  serialNumbers   Json?    // ["SN-001", "SN-002"]

  documentNumber  String?
  documentId      String?
  supplier        String?
  customerName    String?
  reason          String?

  performedById   String?
  performedByName String?

  createdAt       DateTime @default(now())

  @@map("stock_movements")
}

// ==================== Stock Document (invoices, acts) ====================
model StockDocument {
  id               String   @id @default(cuid())
  documentNumber   String
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])

  type             String   // receipt | write_off | return_out | adjustment
  status           String   @default("draft")   // draft | confirmed | cancelled

  counterpartyName String?
  counterpartyInn  String?

  totalAmount      Int      @default(0)
  items            Json     // [{ productId, name, qty, price, serialNumbers }]

  notes            String?

  performedById    String?
  performedByName  String?
  confirmedAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("stock_documents")
}

// ==================== Inventory (Stocktaking session) ====================
model Inventory {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  inventoryNumber String            // ИНВ-0001
  status          String @default("in_progress")  // in_progress | completed | cancelled

  items           Json     // [{ productId, name, sku, barcode, systemQty, actualQty, diff, note }]

  totalProducts   Int @default(0)
  checkedProducts Int @default(0)
  surplusCount    Int @default(0)
  shortageCount   Int @default(0)

  notes           String?

  performedById   String?
  performedByName String?

  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("inventories")
}

// ==================== Sale (POS transaction) ====================
model Sale {
  id              String   @id @default(cuid())
  saleNumber      String   @unique
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  customerName    String?
  customerPhone   String?
  customerInn     String?

  subtotal        Int      @default(0)
  discountPercent Float    @default(0)
  discountAmount  Int      @default(0)
  total           Int      @default(0)

  paymentMethod   String   @default("cash")   // cash | card | transfer | mixed
  paymentStatus   String   @default("paid")   // paid | unpaid | partial
  paidAmount      Int      @default(0)

  invoiceGenerated Boolean @default(false)
  invoiceData      Json?

  doctorId        String?
  doctor          User?    @relation("SaleDoctor", fields: [doctorId], references: [id])

  performedById   String?
  performedByName String?
  notes           String?

  syncedTo1C      Boolean  @default(false)
  external1CId    String?

  patientId       String?
  patient         Patient?     @relation(fields: [patientId], references: [id])
  leadId          String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           SaleItem[]

  @@map("sales")
}

// ==================== Sale Item ====================
model SaleItem {
  id         String       @id @default(cuid())
  saleId     String
  sale       Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId  String
  product    OpticProduct @relation(fields: [productId], references: [id])

  name       String
  category   String?
  quantity   Int
  unitPrice  Int
  total      Int

  serialNumbers Json?     // ["NE-F-00001"]

  @@map("sale_items")
}

// ==================== CRM: Sales Funnel ====================

enum LeadSource {
  whatsapp
  instagram
  website
  manual
  referral
}

enum LeadStage {
  new_lead       @map("new")
  contacted
  follow_up
  qualified
  appointment
  visited
  converted
  lost

  // Retention stages
  checkup
  supplies
  renewal
  retention_dialog
  retention_success
  retention_lost
}

model Lead {
  id            String     @id @default(cuid())

  // Contact
  phone         String     // WhatsApp chatId: 77001234567@c.us
  name          String?
  city          String?
  source        LeadSource @default(whatsapp)

  // Funnel
  funnel        String     @default("sales") // "sales" or "retention"
  stage         LeadStage  @default(new_lead)
  assigneeId    String?
  assignee      User?      @relation("AssignedLeads", fields: [assigneeId], references: [id])

  // Partner clinic
  clinicId      String?
  clinic        Organization? @relation("ClinicLeads", fields: [clinicId], references: [id])

  // Appointment
  appointmentAt          DateTime?
  appointmentNotes       String?
  medmundusAppointmentId String?   @unique
  doctorId               String?
  doctor                 User?     @relation("DoctorLeads", fields: [doctorId], references: [id])

  // Marketing & UTMs
  campaignId    String?
  campaign      MarketingCampaign? @relation(fields: [campaignId], references: [id])
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?

  // Metrics
  lostReason      String?
  convertedAt     DateTime?
  revenue         Float?
  acquisitionCost Int       @default(0) // Стоимость привлечения лида (в тенге)

  // LTV & Retention Dates
  lastLensPurchaseDate     DateTime?
  lastSolutionPurchaseDate DateTime?
  nextCheckupDate          DateTime?

  // Link to patient & order
  patientId     String?
  patient       Patient?  @relation(fields: [patientId], references: [id])
  orderId       String?   @unique
  order         Order?    @relation(fields: [orderId], references: [id])

  // Meta
  tags          String[]
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages      ChatMessage[]
  reminders     Reminder[]
  activities    LeadActivity[]

  @@index([stage])
  @@index([assigneeId])
  @@index([phone])
  @@map("leads")
}

model MarketingCampaign {
  id           String      @id @default(cuid())
  campaignId   String      // ID из Meta Ads / Google Ads
  name         String
  source       String      // "facebook" | "google" | "yandex"
  status       String      @default("active") // "active" | "paused" | "completed"
  dailyBudget  Int         @default(0) // Дневной бюджет в тенге
  totalSpend   Int         @default(0) // Всего потрачено
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  leads        Lead[]
  spends       AdSpend[]

  clinicId     String?
  clinic       Organization? @relation(fields: [clinicId], references: [id])

  @@map("marketing_campaigns")
}

model AdSpend {
  id           String            @id @default(cuid())
  campaignId   String
  campaign     MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  spendDate    DateTime          // Дата расхода
  amount       Int               // Потраченная сумма в тенге
  createdAt    DateTime          @default(now())

  @@unique([campaignId, spendDate])
  @@map("ad_spends")
}


model ChatMessage {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel     String   // 'whatsapp' | 'instagram'
  direction   String   // 'incoming' | 'outgoing'
  messageType String   @default("text") // 'text' | 'image' | 'document' | 'audio'
  content     String   @db.Text
  mediaUrl    String?  @db.Text

  // Green API metadata
  externalId  String?  // idMessage from Green API
  status      String?  // 'sent' | 'delivered' | 'read'

  sentBy      String?  // userId of sales manager (for outgoing)
  sentAt      DateTime @default(now())

  @@index([leadId])
  @@map("chat_messages")
}

model Reminder {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type        String   // 'appointment_1d' | 'appointment_2h' | 'follow_up' | 'custom'
  channel     String   @default("whatsapp")
  message     String   @db.Text

  scheduledAt DateTime
  sentAt      DateTime?
  status      String   @default("pending") // 'pending' | 'sent' | 'failed'

  @@index([scheduledAt, status])
  @@map("reminders")
}

model LeadActivity {
  id       String   @id @default(cuid())
  leadId   String
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  action   String   // 'stage_change' | 'note_added' | 'message_sent' | 'appointment_booked'
  details  String?  @db.Text
  userId   String?  // null = bot

  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("lead_activities")
}

model ClinicSubscription {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Organization @relation("ClinicSubscription", fields: [clinicId], references: [id])

  plan       String   // 'start' | 'growth' | 'premium'
  leadsLimit Int
  leadsUsed  Int      @default(0)
  price      Float

  startsAt  DateTime
  expiresAt DateTime
  status    String   @default("active") // 'active' | 'expired' | 'cancelled'

  @@index([clinicId])
  @@map("clinic_subscriptions")
}

model BotScenario {
  id        String   @id @default(cuid())
  trigger   String
  step      Int
  message   String   @db.Text

  nextAction String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("bot_scenarios")
}
// ==================== Bot Configuration (editable via CRM UI) ====================
model BotConfig {
  id            String   @id @default(cuid())
  key           String   @unique   // 'clinic_name' | 'working_hours' | 'address' | 'services' | 'prices' | 'doctors' | 'faq' | 'greeting' | 'system_prompt_extra'
  value         String   @db.Text
  label         String             // Human-readable label for UI
  category      String   @default("general") // general | services | faq
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@map("bot_config")
}

// ==================== AI Bot Session ====================
model BotSession {
  id        String   @id @default(cuid())
  phone     String   @unique          // normalized phone e.g. 77001234567
  leadId    String?                   // linked Lead
  state     String   @default("greeting") // greeting | collecting_name | collecting_date | collecting_time | confirming | done | paused
  collectedName     String?           // extracted patient name
  collectedDate     String?           // extracted preferred date (ISO string)
  collectedTime     String?           // extracted preferred time e.g. "14:00"
  collectedQuestion String?           // last unresolved question from user
  history   Json     @default("[]")   // array of {role, content} for GPT context
  bookedAt  DateTime?                 // final appointment datetime
  patientId String?                   // linked Patient after booking
  followUpCount     Int      @default(0) // tracks automatic reminders sent (1 day, 2 days, etc)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@map("bot_sessions")
}

// ==================== Cash Register & Shift Operations ====================
model CashRegister {
  id              String            @id @default(cuid())
  name            String
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  currentBalance  Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  shifts          CashShift[]
  transactions    CashTransaction[]

  @@map("cash_registers")
}

model CashShift {
  id             String            @id @default(cuid())
  cashRegisterId String
  cashRegister   CashRegister      @relation(fields: [cashRegisterId], references: [id])
  openedById     String
  openedBy       User              @relation("OpenedShifts", fields: [openedById], references: [id])
  closedById     String?
  closedBy       User?             @relation("ClosedShifts", fields: [closedById], references: [id])
  openedAt       DateTime          @default(now())
  closedAt       DateTime?
  status         String            @default("open")
  startingCash   Int
  expectedCash   Int               @default(0)
  actualCash     Int?
  difference     Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  transactions   CashTransaction[]

  @@map("cash_shifts")
}

model CashTransaction {
  id                 String       @id @default(cuid())
  shiftId            String
  shift              CashShift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  cashRegisterId     String
  cashRegister       CashRegister @relation(fields: [cashRegisterId], references: [id])
  transType          String
  paymentMethod      String
  category           String
  amount             Int
  kaspiTransactionId String?
  kaspiStatus        String?
  createdById        String
  createdBy          User         @relation("CreatedTransactions", fields: [createdById], references: [id])
  description        String?
  createdAt          DateTime     @default(now())

  @@map("cash_transactions")
}

// ==================== Global Finances (P&L, Accounts, Payroll) ====================

model CompanyAccount {
  id              String       @id @default(cuid())
  name            String       // e.g. "Kaspi Pay", "Halyk Bank", "Main Safe"
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  balance         Int          @default(0) // Balance in minimal currency unit (e.g. tiyin, or just tenge if integer)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  transactions    FinancialTransaction[]

  @@map("company_accounts")
}

model FinancialTransaction {
  id              String          @id @default(cuid())
  accountId       String
  account         CompanyAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id])
  
  type            String          // 'income' | 'expense'
  category        String          // 'rent', 'salary', 'marketing', 'supplier_payment', 'other'
  amount          Int
  date            DateTime        @default(now())
  description     String?
  
  createdById     String
  createdBy       User            @relation("FinancialTransactionsCreated", fields: [createdById], references: [id])
  
  // Optional link to a specific user (e.g. for salary payout)
  linkedUserId    String?
  linkedUser      User?           @relation("FinancialTransactionsLinked", fields: [linkedUserId], references: [id])
  
  // Optional link to payroll payout
  payrollPayoutId String?
  payrollPayout   PayrollPayout?  @relation(fields: [payrollPayoutId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("financial_transactions")
}

model PayrollRule {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  baseSalary      Int          @default(0) // Fixed monthly salary
  salesPercent    Float        @default(0) // E.g. 5.0 for 5% from sales

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@map("payroll_rules")
}

model PayrollPayout {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  
  periodStart     DateTime
  periodEnd       DateTime
  
  baseAmount      Int          @default(0)
  salesAmount     Int          @default(0)
  totalAmount     Int          @default(0)
  
  status          String       @default("calculated") // 'calculated' | 'paid'
  paidAt          DateTime?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  transactions    FinancialTransaction[]

  @@map("payroll_payouts")
}
