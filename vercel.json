{
  "buildCommand": "npx prisma generate && next build",
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/itigris-sync-clients",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/itigris-sync-products",
      "schedule": "*/15 * * * *"
    }
  ]
}
